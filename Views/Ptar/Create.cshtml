@model InternalControlApp.Models.CreateRiskPtarViewModel
@{
    ViewData["Title"] = "Agregar Elemento PTAR";
}

@section Styles {
    <style>
        .card { border: none; border-radius: 10px; }
        .card-header { background-color: #fff; border-bottom: 1px solid #eaeaea; }
        .form-label { font-weight: 600; color: #495057; font-size: 0.85rem; text-transform: uppercase; }
        
        .btn-custom { background-color: #00A987; border-color: #00A987; color: white; transition: all 0.2s ease; }
        .btn-custom:hover { background-color: #008f72; border-color: #008f72; color: white; box-shadow: 0 4px 8px rgba(0,0,0,0.15); }
        
        .btn-dashed { border: 2px dashed #00A987; color: #00A987; background-color: transparent; font-weight: 600; transition: all 0.2s ease; }
        .btn-dashed:hover { background-color: #e6f6f3; color: #008f72; border-color: #008f72; }
        
        .btn-outline-custom-cyan { color: #00A987; border-color: #00A987; background-color: transparent; transition: all 0.2s ease; }
        .btn-outline-custom-cyan:hover { color: white; background-color: #00A987; border-color: #00A987; box-shadow: 0 4px 8px rgba(0,0,0,0.15); }

        .fadeInAnimation { animation: fadeIn 0.3s ease-in-out; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

        .page-title { color: #333; font-weight: 500; }
        .section-subtitle { font-weight: 600; font-size: 1.1rem; }
        .sticky-footer-card { z-index: 1000; bottom: 0; }
        .factor-title-text { font-weight: 600; font-size: 1rem; }
    </style>
}

@section HeaderButtons {
    <a class="btn btn-custom shadow-sm" asp-action="Index">
        <i class="fas fa-arrow-left me-1"></i> Volver
    </a>
}

<form id="createRiskForm" asp-action="Create" method="post">
    <div class="card shadow-sm mb-4">
        <div class="card-header py-3 bg-white text-center">
            <h1 class="display-6 m-0 page-title">Agregar Nuevo Elemento (PTAR)</h1>
            <br>
            <hr class="mt-3 mb-3 mx-n3" />
            <h5 class="text-secondary m-0 text-start section-subtitle">
                <i class="fas fa-info-circle me-2"></i> Información del Riesgo
            </h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="RiskNumber" class="form-label"></label>
                    <input asp-for="RiskNumber" class="form-control bg-light" />
                    <span asp-validation-for="RiskNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="RiskClassification" class="form-label"></label>
                    <input asp-for="RiskClassification" class="form-control bg-light" />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control bg-light" rows="2"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="ImpactGrade" class="form-label"></label>
                    <input asp-for="ImpactGrade" type="number" class="form-control bg-light" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="OccurrenceProbability" class="form-label"></label>
                    <input asp-for="OccurrenceProbability" type="number" class="form-control bg-light" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Quadrant" class="form-label"></label>
                    <input asp-for="Quadrant" class="form-control bg-light" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Strategy" class="form-label"></label>
                    <input asp-for="Strategy" class="form-control bg-light" />
                </div>
            </div>
        </div>
    </div>

    <div id="factors-container"></div>

    <div class="card shadow-sm mb-0 sticky-bottom border-0 bg-white sticky-footer-card">
        <div class="card-body d-flex gap-3 border-top p-3 align-items-center">
            <button type="button" id="add-factor-btn" class="btn btn-dashed flex-grow-1 py-2">
                <i class="fas fa-plus-circle me-1"></i> Agregar Nuevo Factor de Riesgo
            </button>
            <a asp-action="Index" class="btn btn-sm btn-outline-danger"><i class="fas fa-times me-1"></i> Cancelar</a>
            <button type="submit" class="btn btn-sm btn-outline-custom-cyan"><i class="fas fa-save me-1"></i> Crear Riesgo</button>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const unitsOptions = '@Html.Raw(Json.Serialize(Model.UnitsList))';
        const usersOptions = '@Html.Raw(Json.Serialize(Model.UsersList))';
        const units = JSON.parse(unitsOptions);
        const users = JSON.parse(usersOptions);
        let factorIndex = 0; // Inicializamos en 0 porque es Create

        document.getElementById('add-factor-btn').addEventListener('click', function(e) {
            e.preventDefault(); // Evita cualquier envío accidental del formulario
            addNewFactor();
        });

        // Delegación de eventos para los botones dinámicos (Eliminar y Ocultar)
        document.getElementById('factors-container').addEventListener('click', function(e) {
            const toggleBtn = e.target.closest('.btn-toggle-factor');
            const removeBtn = e.target.closest('.btn-remove-factor');

            if (toggleBtn) toggleFactor(toggleBtn);
            if (removeBtn) removeFactor(removeBtn);
        });

        function generateOptions(optionsList) {
            return optionsList.map(opt => `<option value="${opt.value}">${opt.text}</option>`).join('');
        }

        function addNewFactor() {
            const factorNumber = factorIndex + 1;
            const factorHtml = `
                <div class="card shadow-sm mb-4 factor-card fadeInAnimation">
                    <div class="card-header d-flex justify-content-between align-items-center py-3 bg-light">
                        <h5 class="text-secondary m-0 factor-title factor-title-text">
                            <i class="fas fa-list-ol me-2"></i> Factor de Riesgo #${factorNumber}
                        </h5>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-outline-custom-cyan btn-toggle-factor">
                                <i class="fas fa-chevron-up"></i> Ocultar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger btn-remove-factor">
                                <i class="fas fa-trash-alt"></i> Eliminar
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3 mb-3">
                                <label class="form-label">No. Factor</label>
                                <input name="Factors[${factorIndex}].FactorNumber" class="form-control" />
                            </div>
                            <div class="col-md-9 mb-3">
                                <label class="form-label">Factor de Riesgo</label>
                                <input name="Factors[${factorIndex}].FactorDescription" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Acción de Control *</label>
                            <textarea name="Factors[${factorIndex}].ControlAction" class="form-control" rows="2" required></textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Unidad Administrativa *</label>
                                <select name="Factors[${factorIndex}].UnitId" class="form-select" required>
                                    <option value="">-- Seleccione --</option>
                                    ${generateOptions(units)}
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Responsable *</label>
                                <select name="Factors[${factorIndex}].ResponsibleUserId" class="form-select" required>
                                    <option value="">-- Seleccione --</option>
                                    ${generateOptions(users)}
                                </select>
                            </div>
                        </div>
                        <div class="row">
                             <div class="col-md-6 mb-3">
                                <label class="form-label">Fecha de Inicio</label>
                                <input name="Factors[${factorIndex}].StartDate" type="date" class="form-control" />
                            </div>
                             <div class="col-md-6 mb-3">
                                <label class="form-label">Fecha de Término</label>
                                <input name="Factors[${factorIndex}].EndDate" type="date" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Medios de Verificación</label>
                            <input name="Factors[${factorIndex}].VerificationMeans" class="form-control" />
                        </div>
                    </div>
                </div>`;
            document.getElementById('factors-container').insertAdjacentHTML('beforeend', factorHtml);
            factorIndex++;
        }

        function removeFactor(button) {
            button.closest('.factor-card').remove();
            reindexFactors();
        }

        function toggleFactor(button) {
            const body = button.closest('.factor-card').querySelector('.card-body');
            if (body.style.display === 'none') {
                body.style.display = 'block';
                button.innerHTML = '<i class="fas fa-chevron-up"></i> Ocultar';
            } else {
                body.style.display = 'none';
                button.innerHTML = '<i class="fas fa-chevron-down"></i> Mostrar';
            }
        }

        function reindexFactors() {
            const factorCards = document.querySelectorAll('.factor-card');
            factorIndex = 0;
            factorCards.forEach(function(card) {
                card.querySelectorAll('input, select, textarea').forEach(function(input) {
                    const oldName = input.name;
                    if (oldName) {
                        input.name = oldName.replace(/Factors\[\d+\]/, `Factors[${factorIndex}]`);
                    }
                });

                const titleElement = card.querySelector('.factor-title');
                if(titleElement) {
                    titleElement.innerHTML = `<i class="fas fa-list-ol me-2"></i> Factor de Riesgo #${factorIndex + 1}`;
                }

                factorIndex++;
            });
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}