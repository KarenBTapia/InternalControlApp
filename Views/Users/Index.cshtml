@model IEnumerable<InternalControlApp.Models.User>
@{
    ViewData["Title"] = "Administración de Usuarios";
}

@section HeaderButtons {
    <a class="btn" style="background-color: #00A987; color: white;"
       asp-controller="Coordinador" asp-action="Index">🔙Volver</a>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6">Lista de Usuarios</h1>
    <div>
        <a class="btn btn-primary" asp-action="Create">[+] Agregar Nuevo Usuario</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <input type="text" name="SearchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Buscar por apellidos...">
                <button type="submit" class="btn btn-primary">Buscar</button>
            </div>
        </form>
    </div>
    @* --- CORRECCIÓN: Clase table-responsive añadida --- *@
    <div class="card-body table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>Usuario (Nombre Completo)</th>
                    <th>Correo Electrónico</th>
                    <th>Rol</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@($"{user.LastName}, {user.FirstName}")</td>
                        <td>@user.Email</td>
                        <td>@user.Role.RoleName</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-primary">Editar</a>

                            <form asp-action="Delete" asp-route-id="@user.UserId" method="post" class="d-inline" onsubmit="return confirm('¿Estás seguro de que quieres eliminar a este usuario?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>