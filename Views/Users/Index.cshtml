@model IEnumerable<InternalControlApp.Models.User>
@{
    ViewData["Title"] = "Administración de Usuarios";
}

@section Styles {
    <style>
        .card {
            border: none;
            border-radius: 10px;
        }

        .card-header {
            background-color: #fff;
            border-bottom: 1px solid #eaeaea;
        }

        .btn-custom {
            background-color: #00A987;
            border-color: #00A987;
            color: white;
            transition: all 0.2s ease;
        }

            .btn-custom:hover {
                background-color: #008f72;
                border-color: #008f72;
                color: white;
                box-shadow: 0 4px 8px rgba(0,0,0,0.15);
            }

        .table thead {
            background-color: #f8f9fa;
        }

        .table th, .table td {
            vertical-align: middle;
        }
    </style>
}

@section HeaderButtons {
    <a class="btn btn-custom shadow-sm" asp-controller="Coordinador" asp-action="Index">
        <i class="fas fa-arrow-left me-1"></i> Volver
    </a>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6 m-0" style="color: #333; font-weight: 500;">Lista de Usuarios</h1>
    <a class="btn btn-custom shadow-sm" asp-action="Create">
        <i class="fas fa-user-plus me-1"></i> Agregar Nuevo Usuario
    </a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header py-3 bg-white">
        <form asp-action="Index" method="get" class="m-0">
            <div class="row">
                <div class="col-md-6 col-lg-4">
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="SearchString" value="@ViewData["CurrentFilter"]" class="form-control border-start-0 ps-0" placeholder="Buscar por apellidos...">
                        <button type="submit" class="btn btn-custom px-4">Buscar</button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3">Usuario (Nombre Completo)</th>
                        <th class="py-3">Correo Electrónico</th>
                        <th class="py-3">Rol</th>
                        <th class="text-center pe-4 py-3">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="fas fa-users fa-2x mb-3 d-block"></i> No se encontraron usuarios registrados.
                            </td>
                        </tr>
                    }
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-secondary">@($"{user.LastName}, {user.FirstName}")</td>
                            <td>@user.Email</td>
                            <td><span class="badge bg-secondary px-3 py-2">@user.Role.RoleName</span></td>
                            <td class="text-center pe-4">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-primary" title="Editar">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@user.UserId" method="post" onsubmit="return confirm('¿Estás seguro de que quieres eliminar a este usuario?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>