@model InternalControlApp.Models.CreateElementPtciViewModel
@{
    ViewData["Title"] = "Agregar Elemento PTCI";
}

@section Styles {
    <style>
        .card {
            border: none;
            border-radius: 10px;
        }

        .card-header {
            background-color: #fff;
            border-bottom: 1px solid #eaeaea;
        }

        .form-label {
            font-weight: 600;
            color: #495057;
            font-size: 0.85rem;
            text-transform: uppercase;
        }

        .btn-custom {
            background-color: #00A987;
            border-color: #00A987;
            color: white;
            transition: all 0.2s ease;
        }

            .btn-custom:hover {
                background-color: #008f72;
                border-color: #008f72;
                color: white;
                box-shadow: 0 4px 8px rgba(0,0,0,0.15);
            }

        .btn-dashed {
            border: 2px dashed #00A987;
            color: #00A987;
            background-color: transparent;
            font-weight: 600;
            transition: all 0.2s ease;
        }

            .btn-dashed:hover {
                background-color: #e6f6f3;
                color: #008f72;
                border-color: #008f72;
            }

        .btn-outline-custom-cyan {
            color: #00A987;
            border-color: #00A987;
            background-color: transparent;
            transition: all 0.2s ease;
        }

            .btn-outline-custom-cyan:hover {
                color: white;
                background-color: #00A987;
                border-color: #00A987;
                box-shadow: 0 4px 8px rgba(0,0,0,0.15);
            }

        .fadeInAnimation {
            animation: fadeIn 0.3s ease-in-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
}

@section HeaderButtons {
    <a class="btn btn-custom shadow-sm" asp-action="Index">
        <i class="fas fa-arrow-left me-1"></i> Volver
    </a>
}

<form asp-action="Create" method="post" id="ptciForm">
    <div class="card shadow-sm mb-4">
        <div class="card-header py-3 bg-white text-center">
            <h1 class="display-6 m-0" style="color: #333; font-weight: 500;">Agregar Nuevo Elemento (PTCI)</h1>
            <br>
            <hr class="mt-3 mb-3 mx-n3" />
            <h5 class="text-secondary m-0 text-start" style="font-weight: 600; font-size: 1.1rem;">
                <i class="fas fa-info-circle me-2"></i> Información del Elemento de Control
            </h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Ngci" class="form-label">NGCI *</label>
                    <input asp-for="Ngci" class="form-control bg-light" required />
                    <span asp-validation-for="Ngci" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ControlNumber" class="form-label">No. Control *</label>
                    <input asp-for="ControlNumber" class="form-control bg-light" required />
                    <span asp-validation-for="ControlNumber" class="text-danger small"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="ControlElement" class="form-label">Elemento de Control *</label>
                <textarea asp-for="ControlElement" class="form-control bg-light" rows="2" required></textarea>
                <span asp-validation-for="ControlElement" class="text-danger small"></span>
            </div>
        </div>
    </div>

    <div id="actions-container"></div>

    <div class="card shadow-sm mb-0 sticky-bottom border-0 bg-white" style="z-index: 1000; bottom: 0;">
        <div class="card-body d-flex gap-3 border-top p-3 align-items-center">
            <button type="button" id="add-action-btn" class="btn btn-dashed flex-grow-1 py-2">
                <i class="fas fa-plus-circle me-1"></i> Agregar Nueva Acción de Mejora
            </button>
            <a asp-action="Index" class="btn btn-sm btn-outline-danger"><i class="fas fa-times me-1"></i> Cancelar</a>
            <button type="submit" class="btn btn-sm btn-outline-custom-cyan"><i class="fas fa-save me-1"></i> Guardar Cambios</button>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        var unitsOptions = '@Html.Raw(Json.Serialize(Model.UnitsList))';
        var usersOptions = '@Html.Raw(Json.Serialize(Model.UsersList))';

        var units = JSON.parse(unitsOptions);
        var users = JSON.parse(usersOptions);

        var actionIndex = 0;

        document.getElementById('add-action-btn').addEventListener('click', function() {
            addNewAction();
        });

        function generateOptions(optionsList) {
            return optionsList.map(opt => `<option value="${opt.value}">${opt.text}</option>`).join('');
        }

        function addNewAction() {
            var actionNumber = actionIndex + 1;
            var actionHtml = `
                <div class="card shadow-sm mb-4 action-card fadeInAnimation">
                    <div class="card-header d-flex justify-content-between align-items-center py-3 bg-light">
                        <h5 class="text-secondary m-0 action-title" style="font-weight: 600; font-size: 1rem;">
                            <i class="fas fa-list-ol me-2"></i> Acción de Mejora #${actionNumber}
                        </h5>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-outline-custom-cyan" onclick="toggleAction(this)">
                                <i class="fas fa-chevron-up"></i> Ocultar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeAction(this)">
                                <i class="fas fa-trash-alt"></i> Eliminar
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Proceso *</label>
                                <input name="Actions[${actionIndex}].Process" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">No. Acción *</label>
                                <input name="Actions[${actionIndex}].ActionNumber" class="form-control" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Acción de Mejora *</label>
                            <textarea name="Actions[${actionIndex}].ImprovementAction" class="form-control" rows="2" required></textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Unidad Administrativa *</label>
                                <select name="Actions[${actionIndex}].UnitId" class="form-select" required>
                                    <option value="">-- Seleccione --</option>
                                    ${generateOptions(units)}
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Responsable *</label>
                                <select name="Actions[${actionIndex}].ResponsibleUserId" class="form-select" required>
                                    <option value="">-- Seleccione --</option>
                                    ${generateOptions(users)}
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Fecha de Inicio *</label>
                                <input name="Actions[${actionIndex}].StartDate" type="date" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Fecha de Término *</label>
                                <input name="Actions[${actionIndex}].EndDate" type="date" class="form-control" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Medios de Verificación *</label>
                            <input name="Actions[${actionIndex}].VerificationMeans" class="form-control" required />
                        </div>
                    </div>
                </div>
            `;

            document.getElementById('actions-container').insertAdjacentHTML('beforeend', actionHtml);
            actionIndex++;
        }

        function removeAction(button) {
            button.closest('.action-card').remove();
            reindexActions();
        }

        function toggleAction(button) {
            var body = button.closest('.action-card').querySelector('.card-body');
            if (body.style.display === 'none') {
                body.style.display = 'block';
                button.innerHTML = '<i class="fas fa-chevron-up"></i> Ocultar';
            } else {
                body.style.display = 'none';
                button.innerHTML = '<i class="fas fa-chevron-down"></i> Mostrar';
            }
        }

        function reindexActions() {
            var actionCards = document.querySelectorAll('.action-card');
            actionIndex = 0;

            actionCards.forEach(function(card) {
                card.querySelectorAll('input, select, textarea').forEach(function(input) {
                    var oldName = input.name;
                    if (oldName) {
                        input.name = oldName.replace(/Actions\[\d+\]/, `Actions[${actionIndex}]`);
                    }
                });

                var titleElement = card.querySelector('.action-title');
                if(titleElement) {
                    titleElement.innerHTML = `<i class="fas fa-list-ol me-2"></i> Acción de Mejora #${actionIndex + 1}`;
                }

                actionIndex++;
            });
        }
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}