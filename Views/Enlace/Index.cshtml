@model InternalControlApp.Models.EnlaceDashboardViewModel
@using X.PagedList.Mvc.Core;
@{
    ViewData["Title"] = "Dashboard de Tareas";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card shadow-sm mb-5">
    <div class="card-header bg-light">
        <h5 class="my-1">Evidencias con Sugerencias</h5>
    </div>
    <div class="card-body coor-table-container p-0">
        <table class="coor-table">
            <thead>
                <tr>
                    <th class="coor-sticky-th coor-text-center">Programa</th>
                    <th class="coor-sticky-th d-none-mobile coor-text-center">No. Elemento/Riesgo</th>
                    <th class="coor-sticky-th coor-text-center">Fecha y Hora de Revisión</th>
                    <th class="coor-sticky-th coor-text-center">Estatus</th>
                    <th class="coor-sticky-th coor-text-center">Acción</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.TareasPendientes.Any())
                {
                    <tr><td colspan="5" class="coor-text-center text-muted">No tienes evidencias con sugerencias.</td></tr>
                }
                @foreach (var item in Model.TareasPendientes)
                {
                    <tr>
                        <td class="coor-text-center">
                            @if (item.ActionIdPtci != null)
                            {
                                <span class="badge badge-ptci">PTCI</span>
                            }
                            else
                            {
                                <span class="badge badge-ptar">PTAR</span>
                            }
                        </td>
                        <td class="d-none-mobile coor-text-center">@(item.ActionIdPtci != null ? item.ActionIdPtciNavigation?.Element?.ControlNumber : item.FactorIdPtarNavigation?.Risk?.RiskNumber)</td>
                        <td class="coor-text-center">@(item.ReviewDate?.ToString("dd/MM/yyyy HH:mm"))</td>
                        <td class="coor-text-center">
                            @if (item.Status == "Sugerencia")
                            {
                                <span class="badge bg-warning text-dark">Sugerencia</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pendiente</span>
                            }
                        </td>
                        <td class="coor-text-center">
                            <a class="btn btn-sm btn-custom" asp-action="Review" asp-route-id="@item.DeliveryId">Revisar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-light">
        @Html.PagedListPager(Model.TareasPendientes, pagePendientes => Url.Action("Index", new { pagePendientes }), new PagedListRenderOptions { UlElementClasses = new string[] { "coor-pagination" }, LiElementClasses = new string[] { "page-item" }, PageClasses = new string[] { "page-link" } })
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="my-1">Historial de Evidencias Aprobadas</h5>
        <form asp-action="HideApprovedHistory" method="post" onsubmit="return confirm('¿Estás seguro de que quieres archivar todo tu historial de entregas aprobadas?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash-alt"></i> Borrar Historial</button>
        </form>
    </div>
    <div class="card-body coor-table-container p-0">
        <table class="coor-table">
            <thead>
                <tr>
                    <th class="coor-sticky-th coor-text-center">Programa</th>
                    <th class="coor-sticky-th d-none-mobile coor-text-center">No. Elemento/Riesgo</th>
                    <th class="coor-sticky-th coor-text-center">Fecha y Hora de Aprobación</th>
                    <th class="coor-sticky-th coor-text-center">Estatus</th>
                    <th class="coor-sticky-th coor-text-center">Acción</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.HistorialDeEntregas.Any())
                {
                    <tr><td colspan="5" class="coor-text-center text-muted">No tienes evidencias aprobadas en tu historial.</td></tr>
                }
                @foreach (var item in Model.HistorialDeEntregas)
                {
                    <tr>
                        <td class="coor-text-center">
                            @if (item.ActionIdPtci != null)
                            {
                                <span class="badge badge-ptci">PTCI</span>
                            }
                            else
                            {
                                <span class="badge badge-ptar">PTAR</span>
                            }
                        </td>
                        <td class="d-none-mobile coor-text-center">@(item.ActionIdPtci != null ? item.ActionIdPtciNavigation?.Element?.ControlNumber : item.FactorIdPtarNavigation?.Risk?.RiskNumber)</td>
                        <td class="coor-text-center">@(item.ReviewDate?.ToString("dd/MM/yyyy HH:mm"))</td>
                        <td class="coor-text-center"><span class="badge bg-success">Aprobado</span></td>
                        <td class="coor-text-center">
                            <a asp-action="Review" asp-route-id="@item.DeliveryId" class="btn btn-sm btn-custom">Ver</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-light">
        @Html.PagedListPager(Model.HistorialDeEntregas, pageHistorial => Url.Action("Index", new { pageHistorial }), new PagedListRenderOptions { UlElementClasses = new string[] { "coor-pagination" }, LiElementClasses = new string[] { "page-item" }, PageClasses = new string[] { "page-link" } })
    </div>
</div>