@using System.Text.Json
@model InternalControlApp.Models.EnlaceReviewViewModel
@{
    ViewData["Title"] = "Detalle de Entrega";
    var isSugerencia = Model.Status == "Sugerencia";
    var statusClass = isSugerencia ? "bg-warning text-dark" : "bg-success";
    var controllerName = Model.ProgramType == "PTCI" ? "Ptci" : "Ptar";
    var esPtci = Model.ProgramType == "PTCI";

    var historialJson = new List<dynamic>();
    var textoRetroalimentacion = Model.DirectorFeedback;
    var esJson = false;

    if (!string.IsNullOrEmpty(Model.DirectorFeedback) && Model.DirectorFeedback.Trim().StartsWith("["))
    {
        try
        {
            using (var doc = JsonDocument.Parse(Model.DirectorFeedback))
            {
                foreach (var item in doc.RootElement.EnumerateArray())
                {
                    var autor = item.TryGetProperty("Autor", out var a) ? a.GetString() : "Coordinador";
                    var fechaStr = item.TryGetProperty("Fecha", out var f) ? f.GetString() : "";
                    var comentario = item.TryGetProperty("Comentario", out var c) ? c.GetString() : "";
                    
                    DateTime fechaObj;
                    if (!DateTime.TryParse(fechaStr, out fechaObj)) 
                    {
                        fechaObj = DateTime.Now;
                    }

                    historialJson.Add(new { Autor = autor, Fecha = fechaObj, Comentario = comentario });
                }
            }
            esJson = true;
        }
        catch
        {
            esJson = false;
        }
    }
}

@section HeaderButtons {
    <a class="btn btn-custom shadow-sm" asp-action="Index">
        <i class="fas fa-arrow-left me-1"></i> Volver
    </a>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header py-4 text-center">
                <h1 class="display-6 m-0 mb-3 page-title">Detalle de Entrega</h1>
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="text-secondary text-start mb-0"><i class="fas fa-info-circle me-2"></i> Información de la Entrega</h5>
                    <span class="badge @statusClass px-3 py-2 fs-6 shadow-sm">Estado: @Model.Status</span>
                </div>
            </div>
            <div class="card-body">
                <div class="row mb-4 text-center d-flex align-items-start justify-content-between">
                    <div class="col-xl col-lg-3 col-md-3 mb-3 mb-xl-0">
                        <label class="fw-bold mb-1">Programa</label>
                        <div>
                            <span class="badge @(esPtci ? "badge-ptci" : "badge-ptar") px-3">@Model.ProgramType</span>
                        </div>
                    </div>
                    <div class="col-xl col-lg-3 col-md-3 mb-3 mb-xl-0">
                        <label class="fw-bold mb-1">Trimestre</label>
                        <p class="text-secondary mb-0">@Model.QuarterNumber</p>
                    </div>
                    <div class="col-xl col-lg-3 col-md-3 mb-3 mb-xl-0">
                        <label class="fw-bold mb-1">Fecha de Revisión</label>
                        <p class="text-secondary mb-0">@Model.SubmissionDate.ToString("dd/MM/yyyy")</p>
                    </div>
                    <div class="col-xl col-lg-3 col-md-3">
                        <label class="fw-bold mb-1">No. Elemento</label>
                        <p class="text-secondary mb-0">@Model.ParentTaskNumber</p>
                    </div>
                </div>

                <div class="mt-4">
                    <label class="fw-bold">Elemento Asignado</label>
                    <div class="p-3 rounded border bg-light text-secondary mt-1">
                        <strong>@Model.ParentTaskDescription</strong><br />
                        @Model.TaskDescription
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header py-3">
                <h5><i class="fas fa-paperclip me-2"></i> Archivos de Evidencia Entregados</h5>
            </div>
            <div class="card-body">
                @if (Model.Attachments.Any())
                {
                    <div class="list-group list-group-flush border rounded">
                        @foreach (var file in Model.Attachments)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center attachment-item py-3">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-file-pdf text-danger me-3 fa-lg"></i>
                                    <div>
                                        <span class="d-block text-dark fw-bold">@(file.OriginalFileName.StartsWith("[C]_") ? file.OriginalFileName.Substring(4) : file.OriginalFileName)</span>
                                        @if (file.OriginalFileName.StartsWith("[C]_"))
                                        {
                                            <small class="text-info fw-bold">Añadido por el Coordinador</small>
                                        }
                                    </div>
                                </div>
                                <div class="btn-group shadow-sm">
                                    <a href="~/@file.StoragePath" target="_blank" class="btn btn-sm btn-outline-secondary" title="Ver Archivo">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">No se adjuntaron archivos.</div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header py-3">
                <h5><i class="fas fa-clipboard-check me-2"></i> Evaluación Continua</h5>
            </div>
            <div class="card-body d-flex flex-column">
                <div class="mb-3">
                    <label class="fw-bold mb-1 small">Mi Comentario (Enlace):</label>
                    <div class="bg-light p-2 rounded border comment-box">
                        "@(Model.UserComment ?? "Sin comentario.")"
                    </div>
                </div>
                
                <div class="flex-grow-1 mt-2">
                    <label class="form-label fw-bold mb-2 small">Historial de Observaciones:</label>
                    <div class="historial-container border rounded bg-light p-3">
                        @if (esJson && historialJson.Any())
                        {
                            @foreach (var obs in historialJson)
                            {
                                <div class="mensaje-historial">
                                    <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                                        <span class="fw-bold badge badge-user">@obs.Autor</span>
                                        <small class="text-muted obs-date">
                                            <i class="fas fa-calendar-alt me-1"></i> @obs.Fecha.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                    </div>
                                    <p class="mb-0 text-dark small obs-text">@obs.Comentario</p>
                                </div>
                            }
                        }
                        else if (!string.IsNullOrEmpty(textoRetroalimentacion))
                        {
                            <div class="mensaje-historial">
                                <p class="mb-0 text-dark small obs-text">@textoRetroalimentacion</p>
                            </div>
                        }
                        else
                        {
                            <div class="text-center text-muted small py-4">
                                <i class="fas fa-comments fs-4 mb-2 text-light"></i><br />
                                <em>Aún no hay retroalimentación registrada.</em>
                            </div>
                        }
                    </div>
                </div>

                @if (isSugerencia)
                {
                    <div class="mt-4 d-grid">
                        <a asp-controller="@controllerName" asp-action="Upload" asp-route-id="@Model.ParentTaskId" class="btn btn-warning shadow-sm py-2 fw-bold text-dark">
                            <i class="fas fa-edit me-1"></i> Ir a Corregir Evidencia
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>