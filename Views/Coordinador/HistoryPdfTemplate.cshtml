@model IEnumerable<InternalControlApp.Models.Delivery>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Historial de Revisiones</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 9px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid #cccccc;
            text-align: left;
            padding: 4px;
            word-wrap: break-word;
        }

        th {
            background-color: #f2f2f2;
            text-align: center;
        }

        .header {
            text-align: center;
            margin-bottom: 20px;
        }

        h2, h4 {
            margin: 0;
            padding: 0;
        }

        .comment-column {
            width: 25%; /* Asigna más espacio a las columnas de comentarios */
        }
    </style>
</head>
<body>
    <div class="header">
        <h2>Historial de Revisiones</h2>
        <h4>Fecha de Generación: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</h4>
    </div>
    <table>
        <thead>
            <tr>
                <th>Programa</th>
                <th>Usuario</th>
                <th>Fecha Revisión</th>
                <th>Estatus</th>
                <th class="comment-column">Comentario del Enlace</th>
                <th class="comment-column">Retroalimentación del Coordinador</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="text-align: center;">@(item.ActionIdPtci != null ? "PTCI" : "PTAR")</td>
                    <td>@($"{item.User?.FirstName} {item.User?.LastName}")</td>
                    <td style="text-align: center;">@(item.ReviewDate?.ToString("dd/MM/yy HH:mm"))</td>
                    <td style="text-align: center;">@item.Status</td>
                    <td>@item.UserComment</td>
                    <td>@item.DirectorFeedback</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>