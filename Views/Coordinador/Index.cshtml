@model InternalControlApp.Models.DashboardViewModel
@using X.PagedList.Mvc.Core;

@{
    ViewData["Title"] = "Dashboard del Coordinador";
    int currentPageSize = Context.Request.Query["pageSize"].ToString() != ""
        ? int.Parse(Context.Request.Query["pageSize"])
        : 10;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get">
            <input type="hidden" name="pageSize" value="@currentPageSize" />
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold small text-muted">BUSCAR</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="searchString" value="@Model.CurrentSearch" class="form-control" placeholder="Usuario...">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-muted">DESDE</label>
                    <input type="date" name="reviewStartDate" value="@Model.ReviewStartDate?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-muted">HASTA</label>
                    <input type="date" name="reviewEndDate" value="@Model.ReviewEndDate?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-custom w-100">
                        <i class="fas fa-filter"></i> <span class="btn-text">Filtrar</span>
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary" title="Limpiar">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm mb-5">
    <div class="card-header border-bottom-0 pt-3 px-3 pb-0">
        <ul class="nav nav-tabs card-header-tabs m-0" id="dashboardTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="pendientes-tab" data-bs-toggle="tab" data-bs-target="#pendientes" type="button" role="tab">
                    Pendientes de Revisar
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="historial-tab" data-bs-toggle="tab" data-bs-target="#historial" type="button" role="tab">
                    Historial de Revisiones
                </button>
            </li>
        </ul>
    </div>

    <div class="card-body p-0 border-top">
        <div class="tab-content" id="dashboardTabsContent">

            <div class="tab-pane fade show active" id="pendientes" role="tabpanel" aria-labelledby="pendientes-tab">
                <div class="p-3 bg-white border-bottom d-flex justify-content-end align-items-center gap-3">
                    <form asp-action="Index" method="get" class="d-flex align-items-center m-0">
                        <input type="hidden" name="searchString" value="@Model.CurrentSearch" />
                        <input type="hidden" name="reviewStartDate" value="@Model.ReviewStartDate?.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="reviewEndDate" value="@Model.ReviewEndDate?.ToString("yyyy-MM-dd")" />
                        <label class="me-2 small text-muted fw-bold mb-0">Mostrar:</label>
                        <input type="number" name="pageSize" value="@currentPageSize" min="1" max="100" class="form-control form-control-sm text-center page-size-input auto-submit-input" style="width:70px;">
                    </form>
                    <div class="m-0">
                        @Html.PagedListPager(Model.PendientesDeRevisar, pagePendientes => Url.Action("Index", new { pagePendientes, searchString = Model.CurrentSearch, reviewStartDate = Model.ReviewStartDate, reviewEndDate = Model.ReviewEndDate, pageSize = currentPageSize }),
                        new PagedListRenderOptions { LiElementClasses = new string[] { "page-item" }, PageClasses = new string[] { "page-link" }, UlElementClasses = new string[] { "pagination pagination-sm m-0" } })
                    </div>
                </div>

                <div class="coor-table-container">
                    <table class="coor-table">
                        <thead>
                            <tr>
                                <th class="coor-sticky-th coor-col-program">Programa</th>
                                <th class="coor-sticky-th d-none-mobile">No. Elemento/Riesgo</th>
                                <th class="coor-sticky-th">Usuario</th>
                                <th class="coor-sticky-th">Avance</th>
                                <th class="coor-sticky-th">Trimestre</th>
                                <th class="coor-sticky-th d-none-mobile">Fecha Entrega</th>
                                <th class="coor-sticky-th">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.PendientesDeRevisar?.Any() == true)
                            {
                                foreach (var item in Model.PendientesDeRevisar)
                                {
                                    var esPtci = item.ActionIdPtci != null;
                                    <tr>
                                        <td><span class="badge @(esPtci ? "badge-ptci" : "badge-ptar")">@(esPtci ? "PTCI" : "PTAR")</span></td>
                                        <td class="d-none-mobile small text-muted">@(esPtci? item.ActionIdPtciNavigation?.Element?.ControlNumber : item.FactorIdPtarNavigation?.Risk?.RiskNumber)</td>
                                        <td class="fw-bold text-secondary">@item.User?.FirstName @item.User?.LastName</td>
                                        <td><p class="text-muted mb-0">@item.Grade %</p></td>
                                        <td class="small">@item.QuarterNumber</td>
                                        <td class="d-none-mobile small">@item.SubmissionDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <a class="btn btn-sm px-3 btn-warning" asp-action="Review" asp-route-id="@item.DeliveryId">
                                                <i class="fas fa-edit me-1"></i> Revisar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="py-5 text-muted text-center">
                                        <i class="fas fa-inbox fa-2x mb-3 d-block"></i> No hay entregas pendientes de revisión.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="historial" role="tabpanel" aria-labelledby="historial-tab">
                <div class="p-3 bg-light border-bottom d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-info" asp-action="ExportHistoryToPdf" asp-route-searchString="@Model.CurrentSearch" asp-route-reviewStartDate="@Model.ReviewStartDate?.ToString("yyyy-MM-dd")" asp-route-reviewEndDate="@Model.ReviewEndDate?.ToString("yyyy-MM-dd")">
                            <i class="fas fa-file-pdf"></i> <span class="d-none d-md-inline">Exportar PDF</span>
                        </a>
                        <form asp-action="HideReviewHistory" method="post" class="form-confirm-archive">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="fas fa-archive"></i> <span class="d-none d-md-inline">Archivar</span>
                            </button>
                        </form>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <form asp-action="Index" method="get" class="d-flex align-items-center m-0">
                            <input type="hidden" name="searchString" value="@Model.CurrentSearch" />
                            <input type="hidden" name="reviewStartDate" value="@Model.ReviewStartDate?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="reviewEndDate" value="@Model.ReviewEndDate?.ToString("yyyy-MM-dd")" />
                            <label class="me-2 small text-muted fw-bold mb-0">Mostrar:</label>
                            <input type="number" name="pageSize" value="@currentPageSize" min="1" max="100" class="form-control form-control-sm text-center page-size-input auto-submit-input" style="width:70px;">
                        </form>
                        <div class="m-0">
                            @Html.PagedListPager(Model.HistorialDeRevisiones, pageHistorial => Url.Action("Index", new { pageHistorial, searchString = Model.CurrentSearch, reviewStartDate = Model.ReviewStartDate, reviewEndDate = Model.ReviewEndDate, pageSize = currentPageSize }),
                            new PagedListRenderOptions { LiElementClasses = new string[] { "page-item" }, PageClasses = new string[] { "page-link" }, UlElementClasses = new string[] { "pagination pagination-sm m-0" } })
                        </div>
                    </div>
                </div>

                <div class="coor-table-container">
                    <table class="coor-table">
                        <thead>
                            <tr>
                                <th class="coor-sticky-th coor-col-program">Programa</th>
                                <th class="coor-sticky-th d-none-mobile">No. Elemento</th>
                                <th class="coor-sticky-th">Usuario</th>
                                <th class="coor-sticky-th">Trimestre</th>
                                <th class="coor-sticky-th d-none-mobile">Fecha Revisión</th>
                                <th class="coor-sticky-th">Estatus</th>
                                <th class="coor-sticky-th">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.HistorialDeRevisiones?.Any() == true)
                            {
                                foreach (var item in Model.HistorialDeRevisiones)
                                {
                                    var esPtci = item.ActionIdPtci != null;
                                    <tr>
                                        <td><span class="badge @(esPtci ? "badge-ptci" : "badge-ptar")">@(esPtci ? "PTCI" : "PTAR")</span></td>
                                        <td class="d-none-mobile small text-muted">@(esPtci? item.ActionIdPtciNavigation?.Element?.ControlNumber : item.FactorIdPtarNavigation?.Risk?.RiskNumber)</td>
                                        <td class="text-secondary">@item.User?.FirstName @item.User?.LastName</td>
                                        <td class="small">@item.QuarterNumber</td>
                                        <td class="small d-none-mobile">@item.ReviewDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td><span class="badge @(item.Status == "Aprobado" ? "bg-success" : "bg-warning text-dark")">@item.Status</span></td>
                                        <td>
                                            <a class="btn btn-sm px-3 btn-warning" asp-action="Review" asp-route-id="@item.DeliveryId">
                                                <i class="fas fa-eye me-1"></i> Revisar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="7" class="py-5 text-muted text-center">No se encontraron registros en el historial.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

<button id="backToTopBtn" class="btn-back-to-top" title="Ir arriba">
    <i class="fas fa-arrow-up"></i>
</button>

@section Scripts {
    <script>
        $(function() {
            const activeTab = localStorage.getItem('activeDashboardTab');
            if (activeTab) {
                const tabEl = document.querySelector(activeTab);
                if (tabEl) new bootstrap.Tab(tabEl).show();
            }

            $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function(e) {
                const targetId = $(e.target).attr('id');
                localStorage.setItem('activeDashboardTab', '#' + targetId);
            });

            $(window).scroll(function() {
                $('#backToTopBtn').toggle($(this).scrollTop() > 100);
            });

            $('#backToTopBtn').on('click', function() {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });

            $('.auto-submit-input').on('change', function() {
                $(this).closest('form').submit();
            });

            $('.form-confirm-archive').on('submit', function() {
                return confirm('¿Está seguro de que desea archivar el historial de revisiones seleccionado?');
            });
        });
    </script>
}