@model InternalControlApp.Models.DashboardViewModel
@using X.PagedList.Mvc.Core;

@{
    ViewData["Title"] = "Dashboard del Coordinador";
    int currentPageSize = ViewBag.PageSize ?? 10;
}

@section Styles {
    <style>
        .card { border: none; border-radius: 10px; }
        .card-header { background-color: #fff; border-bottom: none; }
        .nav-tabs { gap: 0; padding: 0 1rem; border-bottom: 1px solid #dee2e6; }
        .nav-tabs .nav-link {
            color: #6c757d; font-weight: 600; border: 1px solid #dee2e6; border-bottom: none;
            background-color: #f8f9fa; border-radius: 0; padding: 0.8rem 2rem; margin-right: -1px; transition: all 0.2s ease;
        }
        .nav-tabs .nav-link:hover { background-color: #e2e6ea; color: #333; box-shadow: 0 -4px 8px rgba(0,0,0,0.12); z-index: 2; }
        .nav-tabs .nav-link.active { background: #00A987; color: white !important; border-color: #00A987; z-index: 3; box-shadow: none; }
        .btn-custom { background-color: #00A987; border-color: #00A987; color: white; transition: all 0.2s ease; }
        .btn-custom:hover { background-color: #008f72; border-color: #008f72; color: white; box-shadow: 0 4px 8px rgba(0,0,0,0.15); }
        .btn-back-to-top {
            position: fixed; bottom: 30px; right: 30px; width: 50px; height: 50px; border-radius: 50%;
            background-color: #00A987; color: white; border: none; display: none; align-items: center;
            justify-content: center; z-index: 9999; font-size: 1.2rem; box-shadow: 0 4px 10px rgba(0,0,0,0.3); cursor: pointer;
        }
        .badge-ptci, .badge-ptar { color: white; }
        .badge-ptci { background-color: #D4693B; }
        .badge-ptar { background-color: #0887A0; }
        .table thead { background-color: #f8f9fa; }
        .table th, .table td { vertical-align: middle; text-align: center; }
        .pagination { margin-bottom: 0; }
        .pagination .page-link { color: #6c757d; background-color: #f8f9fa; border-color: #dee2e6; font-weight: 600; transition: all 0.2s ease; }
        .pagination .page-link:hover { background-color: #e2e6ea; color: #333; box-shadow: 0 4px 8px rgba(0,0,0,0.15); z-index: 2; }
        .pagination .page-item.active .page-link { background-color: #00A987; border-color: #00A987; color: white !important; box-shadow: none; }

        @@media (max-width: 768px) {
            .d-none-mobile, .btn-text { display: none !important; }
            .nav-tabs .nav-link { width: 100%; text-align: center; margin-right: 0; margin-bottom: -1px; }
            .pagination-container { flex-direction: column; align-items: stretch !important; }
        }
    </style>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="post" id="searchForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="formAction" value="search" />
            <input type="hidden" name="pageSize" value="@currentPageSize" />
            
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold small text-muted">BUSCAR</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="searchString" value="@Model.CurrentSearch" class="form-control" placeholder="Usuario...">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-muted">DESDE</label>
                    <input type="date" name="reviewStartDate" value="@Model.ReviewStartDate?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-muted">HASTA</label>
                    <input type="date" name="reviewEndDate" value="@Model.ReviewEndDate?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-custom w-100"><i class="fas fa-filter"></i> <span class="btn-text">Filtrar</span></button>
                    <a asp-action="Index" asp-route-clear="true" class="btn btn-outline-secondary" title="Limpiar"><i class="fas fa-times"></i></a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm mb-5">
    <div class="card-header border-bottom-0 pt-3 px-3 pb-0">
        <ul class="nav nav-tabs card-header-tabs m-0" id="dashboardTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="pendientes-tab" data-bs-toggle="tab" data-bs-target="#pendientes" type="button" role="tab" aria-controls="pendientes" aria-selected="true">
                    Pendientes de Revisar
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="historial-tab" data-bs-toggle="tab" data-bs-target="#historial" type="button" role="tab" aria-controls="historial" aria-selected="false">
                    Historial de Revisiones
                </button>
            </li>
        </ul>
    </div>

    <div class="card-body p-0 border-top">
        <div class="tab-content" id="dashboardTabsContent">

            <div class="tab-pane fade show active" id="pendientes" role="tabpanel" aria-labelledby="pendientes-tab">
                <div class="p-3 bg-white border-bottom d-flex justify-content-end align-items-center gap-3 pagination-container">
                    
                    <form asp-action="Index" method="post" class="d-flex align-items-center m-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="formAction" value="pageSize" />
                        <label class="me-2 small text-muted fw-bold mb-0">Mostrar:</label>
                        <input type="number" name="pageSize" value="@currentPageSize" min="1" max="100" class="form-control form-control-sm text-center" style="width: 70px;" onchange="this.form.submit()">
                    </form>

                    <div class="m-0 pagination-pendientes">
                        @Html.PagedListPager(Model.PendientesDeRevisar, pagePendientes => Url.Action("Index", new { pagePendientes }),
                        new PagedListRenderOptions { 
                            LiElementClasses = new string[] { "page-item" }, 
                            PageClasses = new string[] { "page-link" }, 
                            UlElementClasses = new string[] { "pagination pagination-sm m-0" } 
                        })
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 80px;">Programa</th>
                                <th class="d-none-mobile">No. Elemento/Riesgo</th>
                                <th>Usuario</th>
                                <th>Avance(Enlace)</th>
                                <th>Trimestre</th>
                                <th class="d-none-mobile">Fecha Entrega</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.PendientesDeRevisar != null && Model.PendientesDeRevisar.Any())
                            {
                                foreach (var item in Model.PendientesDeRevisar)
                                {
                                    var esPtci = item.ActionIdPtci != null;
                                    <tr>
                                        <td><span class="badge @(esPtci ? "badge-ptci" : "badge-ptar")">@(esPtci ? "PTCI" : "PTAR")</span></td>
                                        <td class="d-none-mobile small text-muted">@(esPtci? item.ActionIdPtciNavigation?.Element?.ControlNumber : item.FactorIdPtarNavigation?.Risk?.RiskNumber)</td>
                                        <td class="fw-bold text-secondary">@item.User?.FirstName @item.User?.LastName</td>
                                        <td><small class="text-muted">@item.Grade %</small></td>
                                        <td class="d-none-mobile small">@item.QuarterNumber</td>
                                        <td class="d-none-mobile small">@item.SubmissionDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td><a class="btn btn-sm px-3 btn-warning" asp-action="Review" asp-route-id="@item.DeliveryId"><i class="fas fa-edit me-1"></i> Revisar</a></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="7" class="text-center py-5 text-muted"><i class="fas fa-inbox fa-2x mb-3 d-block"></i> No hay entregas pendientes de revisión.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="historial" role="tabpanel" aria-labelledby="historial-tab">
                <div class="p-3 bg-light border-bottom d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-info" asp-action="ExportHistoryToPdf" asp-route-searchString="@Model.CurrentSearch" asp-route-reviewStartDate="@Model.ReviewStartDate?.ToString("yyyy-MM-dd")" asp-route-reviewEndDate="@Model.ReviewEndDate?.ToString("yyyy-MM-dd")">
                            <i class="fas fa-file-pdf"></i> <span class="d-none d-md-inline">Exportar PDF</span>
                        </a>
                        <form asp-action="HideReviewHistory" method="post" onsubmit="return confirm('¿Desea archivar el historial?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-archive"></i> <span class="d-none d-md-inline">Archivar</span></button>
                        </form>
                    </div>

                    <div class="d-flex align-items-center gap-3 pagination-container">
                        <form asp-action="Index" method="post" class="d-flex align-items-center m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="formAction" value="pageSize" />
                            <label class="me-2 small text-muted fw-bold mb-0">Mostrar:</label>
                            <input type="number" name="pageSize" value="@currentPageSize" min="1" max="100" class="form-control form-control-sm text-center" style="width: 70px;" onchange="this.form.submit()">
                        </form>

                        <div class="m-0 pagination-historial">
                            @Html.PagedListPager(Model.HistorialDeRevisiones, pageHistorial => Url.Action("Index", new { pageHistorial }),
                            new PagedListRenderOptions { 
                                LiElementClasses = new string[] { "page-item" }, 
                                PageClasses = new string[] { "page-link" }, 
                                UlElementClasses = new string[] { "pagination pagination-sm m-0" } 
                            })
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 80px;">Programa</th>
                                <th class="d-none-mobile">No. Elemento</th>
                                <th>Usuario</th>
                                <th>Trimestre</th>
                                <th class="d-none-mobile">Fecha Revisión</th>
                                <th>Estatus</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.HistorialDeRevisiones != null && Model.HistorialDeRevisiones.Any())
                            {
                                foreach (var item in Model.HistorialDeRevisiones)
                                {
                                    var esPtci = item.ActionIdPtci != null;
                                    <tr>
                                        <td><span class="badge @(esPtci ? "badge-ptci" : "badge-ptar")">@(esPtci ? "PTCI" : "PTAR")</span></td>
                                        <td class="d-none-mobile small text-muted">@(esPtci? item.ActionIdPtciNavigation?.Element?.ControlNumber : item.FactorIdPtarNavigation?.Risk?.RiskNumber)</td>
                                        <td class="text-secondary">@item.User?.FirstName @item.User?.LastName</td>
                                        <td class="d-none-mobile small">@item.QuarterNumber</td>
                                        <td class="d-none-mobile small">@item.ReviewDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td><span class="badge @(item.Status == "Aprobado" ? "bg-success" : "bg-warning text-dark")">@item.Status</span></td>
                                        <td><a class="btn btn-sm px-3 btn-warning" asp-action="Review" asp-route-id="@item.DeliveryId"><i class="fas fa-eye me-1"></i> Revisar</a></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="7" class="text-center py-5 text-muted">No se encontraron registros en el historial.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

<button onclick="scrollToTop()" id="backToTopBtn" class="btn-back-to-top" title="Ir arriba"><i class="fas fa-arrow-up"></i></button>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <script>
        $(function() {
            const activeTab = localStorage.getItem('activeDashboardTab');
            if (activeTab) new bootstrap.Tab(document.querySelector(activeTab)).show();

            $('button[data-bs-toggle="tab"]').on('shown.bs.tab', e => {
                const isPendientes = $(e.target).data('bs-target') === '#pendientes';
                localStorage.setItem('activeDashboardTab', isPendientes ? '#pendientes-tab' : '#historial-tab');
            });
            $(window).scroll(function() { $('#backToTopBtn').toggle($(this).scrollTop() > 100); });
        });
        
        const scrollToTop = () => window.scrollTo({ top: 0, behavior: 'auto' });
        $(document).ready(function () {
            $(document).on('click', '.pagination-pendientes a, .pagination-historial a', function (e) {
                e.preventDefault(); 
                
                var href = $(this).attr('href');
                if (!href || href === '#') return;

                var url = new URL(href, window.location.origin);
                var pagePendientes = url.searchParams.get('pagePendientes');
                var pageHistorial = url.searchParams.get('pageHistorial');

                var $form = $('<form>', {
                    method: 'POST',
                    action: '@Url.Action("Index", "Coordinador")'
                });

                var token = $('#searchForm input[name="__RequestVerificationToken"]').val();
                $('<input>').attr({ type: 'hidden', name: '__RequestVerificationToken', value: token }).appendTo($form);
                
                $('<input>').attr({ type: 'hidden', name: 'formAction', value: 'paginate' }).appendTo($form);

                if (pagePendientes) {
                    $('<input>').attr({ type: 'hidden', name: 'pagePendientes', value: pagePendientes }).appendTo($form);
                }
                
                if (pageHistorial) {
                    $('<input>').attr({ type: 'hidden', name: 'pageHistorial', value: pageHistorial }).appendTo($form);
                }

                $form.appendTo('body').submit();
            });
        });
    </script>
}