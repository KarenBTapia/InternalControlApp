@model InternalControlApp.Models.DashboardViewModel
@using X.PagedList.Mvc.Core;

@{
    ViewData["Title"] = "Dashboard del Coordinador";
    int currentPageSize = Context.Request.Query["pageSize"].ToString() != "" ? int.Parse(Context.Request.Query["pageSize"]) : 10;
}

@section Styles {
    <style>
        .card {
            border: none;
            border-radius: 10px;
        }

        .card-header {
            background-color: #fff;
            border-bottom: none;
        }

        .nav-tabs {
            gap: 0;
            padding: 0 1rem;
            border-bottom: 1px solid #dee2e6;
        }

            .nav-tabs .nav-link {
                color: #6c757d;
                font-weight: 600;
                border: 1px solid #dee2e6;
                border-bottom: none;
                background-color: #f8f9fa;
                border-radius: 0;
                padding: 0.8rem 2rem;
                margin-right: -1px;
                transition: all 0.2s ease;
            }

                .nav-tabs .nav-link:hover {
                    background-color: #e2e6ea;
                    color: #333;
                    z-index: 2;
                }

                .nav-tabs .nav-link.active {
                    background: #00A987 0%;
                    color: white !important;
                    border-color: #00A987;
                    z-index: 3;
                }
                 
            .btn-gradient:hover {
                box-shadow: 0 4px 6px rgba(0,0,0,0.15);
                transform: translateY(-1px);
                filter: brightness(1.1);
                color: white;
            }

        .btn-back-to-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            font-size: 1.2rem;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            cursor: pointer;
        }

        .badge-ptci {
            background-color: #D4693B;
            color: white;
        }

        .badge-ptar {
            background-color: #0887A0;
            color: white;
        }

        .table thead {
            background-color: #f8f9fa;
        }

        .table th, .table td {
            vertical-align: middle;
            text-align: center;
        }

        .toolbar-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.75rem 1rem;
            background-color: #f8f9fa;
            border-bottom: 1px solid #dee2e6;
        }

        .pagination-wrapper {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .page-size-input {
            width: 70px;
            text-align: center;
        }

        .pagination {
            margin-bottom: 0;
        }

        @@media (max-width: 768px) {
            .d-none-mobile {
                display: none !important;
            }

            .btn-text {
                display: none;
            }

            .nav-tabs .nav-link {
                width: 100%;
                text-align: center;
                margin-right: 0;
                margin-bottom: -1px;
            }

            .toolbar-container {
                flex-direction: column;
                gap: 10px;
            }

            .pagination-wrapper {
                flex-direction: column;
                gap: 10px;
            }

            
        }
    </style>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get">
            <input type="hidden" name="pageSize" value="@currentPageSize" />
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold small text-muted">BUSCAR</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" name="searchString" value="@Model.CurrentSearch" class="form-control" placeholder="Usuario...">
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-muted">DESDE</label>
                    <input type="date" name="reviewStartDate" value="@Model.ReviewStartDate?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold small text-muted">HASTA</label>
                    <input type="date" name="reviewEndDate" value="@Model.ReviewEndDate?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-filter"></i> <span class="btn-text">Filtrar</span>
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary" title="Limpiar">
                        X
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm mb-5">
    <div class="card-header border-bottom-0 pt-3 px-3 pb-0">
        <ul class="nav nav-tabs card-header-tabs m-0" id="dashboardTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="pendientes-tab" data-bs-toggle="tab" data-bs-target="#pendientes" type="button" role="tab" aria-controls="pendientes" aria-selected="true">
                    Pendientes de Revisar
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="historial-tab" data-bs-toggle="tab" data-bs-target="#historial" type="button" role="tab" aria-controls="historial" aria-selected="false">
                    Historial de Revisiones
                </button>
            </li>
        </ul>
    </div>

    <div class="card-body p-0 border-top">
        <div class="tab-content" id="dashboardTabsContent">

            <div class="tab-pane fade show active" id="pendientes" role="tabpanel" aria-labelledby="pendientes-tab">
                <div class="toolbar-container bg-white">
                    <div class="flex-grow-1"></div>
                    <div class="pagination-wrapper">
                        <form asp-action="Index" method="get" class="d-flex align-items-center">
                            <input type="hidden" name="searchString" value="@Model.CurrentSearch" />
                            <input type="hidden" name="reviewStartDate" value="@Model.ReviewStartDate?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="reviewEndDate" value="@Model.ReviewEndDate?.ToString("yyyy-MM-dd")" />

                            <label class="me-2 small text-muted fw-bold">Mostrar:</label>
                            <input type="number" name="pageSize" value="@currentPageSize" min="1" max="100" class="form-control form-control-sm page-size-input" onchange="this.form.submit()">
                        </form>

                        <div>
                            @Html.PagedListPager(Model.PendientesDeRevisar, pagePendientes => Url.Action("Index", new { pagePendientes, searchString = Model.CurrentSearch, reviewStartDate = Model.ReviewStartDate, reviewEndDate = Model.ReviewEndDate, pageSize = currentPageSize }),
                            new PagedListRenderOptions { LiElementClasses = new string[] { "page-item" }, PageClasses = new string[] { "page-link" }, UlElementClasses = new string[] { "pagination pagination-sm" } })
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 80px;">Programa</th>
                                <th class="d-none-mobile">No. Elemento/Riesgo</th>
                                <th>Usuario</th>
                                <th>Avance</th>
                                <th>Trimestre</th>
                                <th class="d-none-mobile">Fecha Entrega</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.PendientesDeRevisar != null && Model.PendientesDeRevisar.Any())
                            {
                                foreach (var item in Model.PendientesDeRevisar)
                                {
                                    var esPtci = item.ActionIdPtci != null;
                                    <tr>
                                        <td><span class="badge @(esPtci ? "badge-ptci" : "badge-ptar")">@(esPtci ? "PTCI" : "PTAR")</span></td>
                                        <td class="d-none-mobile small text-muted">@(esPtci? item.ActionIdPtciNavigation?.Element?.ControlNumber : item.FactorIdPtarNavigation?.Risk?.RiskNumber)</td>
                                        <td class="fw-bold text-secondary">@item.User?.FirstName @item.User?.LastName</td>
                                        <!--barra de progreso -->
                                        <td>
                                            <div class="progress mx-auto" style="height: 8px; width: 80px;">
                                                <div class="progress-bar bg-info" style="width:5%"></div>
                                            </div>
                                            <small class="text-muted">5%</small>
                                        </td>
                                        <!--Trimestre -->
                                        <td class="d-none-mobile small">@item.QuarterNumber</td>
                                        <td class="d-none-mobile small">@item.SubmissionDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <a class="btn btn-sm px-3 btn-warning" asp-action="Review" asp-route-id="@item.DeliveryId">
                                                <i class="fas fa-edit me-1"></i> Revisar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        <i class="fas fa-inbox fa-2x mb-3 d-block"></i> No hay entregas pendientes de revisión.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="historial" role="tabpanel" aria-labelledby="historial-tab">
                <div class="toolbar-container bg-light border-bottom">
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-info"
                           asp-action="ExportHistoryToPdf"
                           asp-route-searchString="@Model.CurrentSearch"
                           asp-route-reviewStartDate="@Model.ReviewStartDate?.ToString("yyyy-MM-dd")"
                           asp-route-reviewEndDate="@Model.ReviewEndDate?.ToString("yyyy-MM-dd")">
                            <i class="fas fa-file-pdf"></i> <span class="d-none d-md-inline">Exportar PDF</span>
                        </a>
                        <form asp-action="HideReviewHistory" method="post" onsubmit="return confirm('¿Desea archivar el historial?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="fas fa-archive"></i> <span class="d-none d-md-inline">Archivar</span>
                            </button>
                        </form>
                    </div>

                    <div class="pagination-wrapper mt-2 mt-md-0">
                        <form asp-action="Index" method="get" class="d-flex align-items-center">
                            <input type="hidden" name="searchString" value="@Model.CurrentSearch" />
                            <input type="hidden" name="reviewStartDate" value="@Model.ReviewStartDate?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="reviewEndDate" value="@Model.ReviewEndDate?.ToString("yyyy-MM-dd")" />

                            <label class="me-2 small text-muted fw-bold">Mostrar:</label>
                            <input type="number" name="pageSize" value="@currentPageSize" min="1" max="100" class="form-control form-control-sm page-size-input" onchange="this.form.submit()">
                        </form>

                        <div>
                            @Html.PagedListPager(Model.HistorialDeRevisiones, pageHistorial => Url.Action("Index", new { pageHistorial, searchString = Model.CurrentSearch, reviewStartDate = Model.ReviewStartDate, reviewEndDate = Model.ReviewEndDate, pageSize = currentPageSize }),
                            new PagedListRenderOptions { LiElementClasses = new string[] { "page-item" }, PageClasses = new string[] { "page-link" }, UlElementClasses = new string[] { "pagination pagination-sm" } })
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 80px;">Programa</th>
                                <th class="d-none-mobile">No. Elemento</th>
                                <th>Usuario</th>
                                <th>Trimestre</th>
                                <th class="d-none-mobile">Fecha Revisión</th>
                                <th>Estatus</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.HistorialDeRevisiones)
                            {
                                var esPtci = item.ActionIdPtci != null;
                                <tr>
                                    <td><span class="badge @(esPtci ? "badge-ptci" : "badge-ptar")">@(esPtci ? "PTCI" : "PTAR")</span></td>
                                    <td class="d-none-mobile small text-muted">@(esPtci? item.ActionIdPtciNavigation?.Element?.ControlNumber : item.FactorIdPtarNavigation?.Risk?.RiskNumber)</td>
                                    <td class="text-secondary">@item.User?.FirstName @item.User?.LastName</td>
                                    <td class="d-none-mobile small">Primer trismestre</td>
                                    <td class="d-none-mobile small">@item.ReviewDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td><span class="badge @(item.Status == "Aprobado" ? "bg-success" : "bg-warning text-dark")">@item.Status</span></td>
                                    <td>
                                        <a class="btn btn-sm px-3 btn-warning" asp-action="Review" asp-route-id="@item.DeliveryId">
                                            <i class="fas fa-eye me-1"></i> Revisar
                                        </a>
                                    </td>
                                </tr>
                            }
                            @if (!Model.HistorialDeRevisiones.Any())
                            {
                                <tr><td colspan="6" class="text-center py-5 text-muted">No se encontraron registros en el historial.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

<button onclick="scrollToTop()" id="backToTopBtn" class="btn-gradient btn-back-to-top" title="Ir arriba">
    <i class="fas fa-arrow-up"></i>
</button>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <script>
        $(document).ready(function() {
            var activeTab = localStorage.getItem('activeDashboardTab');
            if (activeTab) {
                var tabTrigger = new bootstrap.Tab(document.querySelector(activeTab));
                tabTrigger.show();
            }
            var tabEls = document.querySelectorAll('button[data-bs-toggle="tab"]');
            tabEls.forEach(function(tabEl) {
                tabEl.addEventListener('shown.bs.tab', function (event) {
                    var targetId = event.target.getAttribute('data-bs-target');
                    var buttonSelector = targetId === '#pendientes' ? '#pendientes-tab' : '#historial-tab';
                    localStorage.setItem('activeDashboardTab', buttonSelector);
                });
            });

            $(window).scroll(function() {
                if ($(this).scrollTop() > 100) {
                    $('#backToTopBtn').fadeIn();
                } else {
                    $('#backToTopBtn').fadeOut();
                }
            });
        });

        function scrollToTop() {
            window.scrollTo({top: 0, behavior: 'smooth'});
        }
    </script>
}