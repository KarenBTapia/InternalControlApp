@model InternalControlApp.Models.ReviewDeliveryViewModel
@{
    ViewData["Title"] = "Revisar Entrega";
}

@section HeaderButtons {
    <a class="btn" style="background-color: #00A987; color: white;" asp-action="Index">🔙Volver</a>
}

@* Mostramos los mensajes de TempData que puedan llegar del controlador *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<h1 class="display-6 mb-4">Revisión de Entrega</h1>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5>Información de la Entrega</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <label class="fw-bold">Usuario (Enlace):</label>
                        <p class="text-muted">@Model.UserName</p>
                    </div>
                    <div class="col-md-6">
                        <label class="fw-bold">Fecha de Entrega:</label>
                        <p class="text-muted">@Model.SubmissionDate.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>
                <hr />
                <div class="row">
                    <div class="col-md-4"><label class="fw-bold">Programa:</label> <p class="text-muted">@Model.ProgramType</p></div>
                    <div class="col-md-4"><label class="fw-bold">Trimestre:</label> <p class="text-muted">@Model.QuarterNumber</p></div>
                    <div class="col-md-4"><label class="fw-bold">No. Elemento/Riesgo:</label> <p class="text-muted">@Model.ParentTaskNumber</p></div>
                </div>
                <div class="mt-2">
                    <label class="fw-bold">Elemento Asignado:</label>
                    <p class="text-muted">@Model.TaskDescription</p>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5>Archivos de Evidencia</h5>
            </div>
            <div class="card-body">
                @if (Model.Attachments.Any())
                {
                    <ul class="list-group">
                        @foreach (var file in Model.Attachments)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @if (file.OriginalFileName.StartsWith("[C]_"))
                                {
                                    // Si tiene la marca, mostramos el mensaje y el nombre limpio
                                    <a href="~/@file.StoragePath" target="_blank">@file.OriginalFileName.Substring(4)</a>
                                    <span class="badge bg-info text-dark">Añadido por el Coordinador</span>
                                }
                                else
                                {
                                    // Si no, lo mostramos normal
                                    <a href="~/@file.StoragePath" target="_blank">@file.OriginalFileName</a>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No se adjuntaron archivos.</p>
                }

                @if (!Model.IsReadOnly)
                {
                    <hr />
                    <h6>Agregar archivo a la entrega:</h6>
                    <form asp-controller="Coordinador" asp-action="AddAttachment" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="deliveryId" value="@Model.DeliveryId" />
                        <div class="input-group">
                            <input type="file" name="file" class="form-control" required />
                            <button type="submit" class="btn btn-primary">[+] Archivo</button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <form asp-action="SubmitReview" method="post">
            <input type="hidden" name="DeliveryId" value="@Model.DeliveryId" />
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5>Evaluación</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="fw-bold">@Model.ContextualInfoLabel:</label>
                        <p class="form-control-plaintext bg-light p-2 rounded">@Model.ContextualInfoText</p>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold">Comentario del Enlace:</label>
                        <p class="form-control-plaintext bg-light p-2 rounded">@(Model.UserComment ?? "Sin comentario.")</p>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DirectorFeedback" class="form-label fw-bold"></label>
                        <textarea asp-for="DirectorFeedback" class="form-control" rows="5"></textarea>
                    </div>
                </div>
                @if (!Model.IsReadOnly)
                {
                    <div class="card-footer d-grid gap-2">
                        <button type="submit" name="decision" value="Aprobado" class="btn btn-success">Aprobar</button>
                        <button type="submit" name="decision" value="Sugerencia" class="btn btn-warning">Devolver con Sugerencias</button>
                    </div>
                }
            </div>
        </form>
    </div>
</div>