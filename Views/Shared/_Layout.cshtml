@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var session = HttpContextAccessor.HttpContext?.Session;
    var roleName = session?.GetString("RoleName");
    var fullName = session?.GetString("FullName");
    
    var isAdminOrCoord = roleName == "Coordinador" || roleName == "Superadmin";
    var isEnlace = roleName == "Enlace";
    
    var hasPtci = session?.GetString("HasPtciTasks") == "True";
    var hasPtar = session?.GetString("HasPtarTasks") == "True";

    var homeController = isAdminOrCoord ? "Coordinador" : "Enlace";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Control Interno</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="main-header">
            <a asp-controller="@homeController" asp-action="Index" class="header-brand">
                <img src="~/images/logo_uttn2.png" alt="Logo UTTN" />
                <span>Sistema de Control Interno Institucional</span>
            </a>
            <a class="btn btn-danger btn-sm" asp-controller="Account" asp-action="Logout"
                   onclick="localStorage.setItem('sesionBloqueada', 'true');">
                <i class="fa-solid fa-right-to-bracket"></i> Cerrar Sesión
            </a>
        </nav>

        <div class="user-bar">
            <div class="user-info">
                <span class="role">@roleName</span>
                <span class="name">@fullName</span>
            </div>

            <div class="dashboard-buttons">
                @if (IsSectionDefined("HeaderButtons"))
                {
                    @RenderSection("HeaderButtons")
                }
                else
                {
                    if (isAdminOrCoord)
                    {
                        <a class="btn btn-sm btn-usuarios" asp-controller="Users" asp-action="Index"><i class="fa-solid fa-users"></i> USUARIOS</a>
                        <a class="btn btn-sm btn-ptci" asp-controller="Ptci" asp-action="Index"><i class="fa-regular fa-rectangle-list"></i> PANEL PTCI</a>
                        <a class="btn btn-sm btn-ptar" asp-controller="Ptar" asp-action="Index"><i class="fa-solid fa-file-circle-exclamation"></i> PANEL PTAR</a>
                    }
                    else if (isEnlace)
                    {
                        if (hasPtci)
                        {
                            <a class="btn btn-sm btn-ptci" asp-controller="Ptci" asp-action="Index"><i class="fa-regular fa-rectangle-list"></i> PANEL PTCI</a>
                        }
                        if (hasPtar)
                        {
                            <a class="btn btn-sm btn-ptar" asp-controller="Ptar" asp-action="Index"><i class="fa-solid fa-file-circle-exclamation"></i> PANEL PTAR</a>
                        }
                    }
                }
            </div>
        </div>
    </header>

    <div class="container-fluid mt-4 px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <partial name="_Footer" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>